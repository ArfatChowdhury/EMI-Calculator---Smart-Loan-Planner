{
  "expo": {
    "name": "EMI-Calculator",
    "slug": "emi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "emicalculatorsmartloanplanner",
    "userInterfaceStyle": "dark",
    "updates": {
      "url": "https://u.expo.dev/emi",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.naim.emicalculator"
    },
    "android": {
      "package": "com.naim.emicalculator",
      "versionCode": 4,
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#0F172A",
          "dark": {
            "backgroundColor": "#0F172A"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3315420037530922~1974149229",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "testDeviceIdentifiers": [
            "6e1beb1f-f162-4d2f-9dc2-78e6d8af6f28"
          ]
        }
      ],
      "expo-font",
      "expo-web-browser",
      "./plugins/withAppCompatResolution",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false,
            "abiFilters": [
              "arm64-v8a",
              "armeabi-v7a",
              "x86_64",
              "x86"
            ],
            "packagingOptions": {
              "pickFirst": [
                "**/libreactnative.so"
              ]
            }
          }
        }
      ]
    ],
    "extra": {
      "privacyPolicyUrl": "https://emi-calculator-smart-loan-website.vercel.app/",
      "termsOfServiceUrl": "https://emi-calculator-smart-loan-website.vercel.app/terms"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}